{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET: Debug serve (--dummy)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/sshrelay/bin/Debug/net8.0/sshrelay.dll",
            "args": ["serve", "--dummy"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": ".NET: Debug serve (SSH)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/sshrelay/bin/Debug/net8.0/sshrelay.dll",
            "args": ["serve"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal"
        },
        {
            "name": ".NET: Debug exec",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/sshrelay/bin/Debug/net8.0/sshrelay.dll",
            "args": ["exec", "--pipe", "sshrelay", "echo hello"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        }
    ]
}
