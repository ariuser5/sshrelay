{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": ["build", "sshrelay.sln"],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build:sshrelay",
            "command": "dotnet",
            "type": "process",
            "args": ["build", "src/sshrelay/sshrelay.csproj"],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test:sshrelay",
            "command": "dotnet",
            "type": "process",
            "args": ["test", "tests/sshrelay.Tests/sshrelay.Tests.csproj"],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "run:sshrelay:serve:dummy",
            "command": "dotnet",
            "type": "process",
            "args": ["run", "--project", "src/sshrelay", "--", "serve", "--dummy"],
            "problemMatcher": []
        },
        {
            "label": "run:dummy-client",
            "command": "dotnet",
            "type": "process",
            "args": ["run", "--project", "src/dummy-client"],
            "problemMatcher": []
        }
    ]
}
